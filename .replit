run = "npm install && npm run build && npm start"
entrypoint = "server/index.ts"
modules = ["nodejs-20", "python-3.11"]

[nix]
channel = "stable-24_05"
packages = ["python311", "python311Packages.pip", "libGL", "zbar", "stdenv.cc.cc.lib", "gcc-unwrapped"]

[deployment]
run = ["sh", "-c", "npm start"]
build = ["sh", "-c", "npm install && npm run build && if [ \"$ENABLE_PYTHON_OCR\" = \"true\" ]; then bash setup-python.sh; else echo 'Skipping Python OCR setup because ENABLE_PYTHON_OCR is not true'; fi"]
deploymentTarget = "gce"

[[ports]]
localPort = 3001
externalPort = 80

[[ports]]
localPort = 8001
externalPort = 8001

[agent]
expertMode = true
