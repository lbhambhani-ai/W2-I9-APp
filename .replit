run = "npm run build && npm start"
entrypoint = "server/index.ts"
modules = ["nodejs-20", "python-3.11"]

[nix]
channel = "stable-24_05"
packages = ["python311", "python311Packages.pip", "libGL", "zbar", "stdenv.cc.cc.lib"]

[deployment]
run = ["sh", "-c", "npm run build && npm start"]
build = ["sh", "-c", "npm install && bash setup-python.sh"]
deploymentTarget = "gce"

[[ports]]
localPort = 3001
externalPort = 80

[[ports]]
localPort = 8001
externalPort = 8001

[agent]
expertMode = true

[userenv]

[userenv.shared]
IDENTITY_VERIFICATION_SERVICE_URL = "https://instawork.app.n8n.cloud/webhook/identity/verify-document"
I9_VERIFICATION_URL = "https://instawork.app.n8n.cloud/webhook/i9/verify-document"
AUDIT_LOG_WEBHOOK_URL = "https://instawork.app.n8n.cloud/webhook/audit-log"
ENABLE_PYTHON_OCR = "true"
PYTHON_OCR_PORT = "8001"
PYTHON_OCR_URL = "http://localhost:8001/verify"
