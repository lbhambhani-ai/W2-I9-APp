# Dependencies
node_modules/
__pycache__/
*.pyc

# Build output
# dist/ — included for Replit deployment (no build step needed)

# Environment variables & secrets — never commit
.env
.env.local
.env.*.local
replit-secrets.json

# Editor / OS
.DS_Store
.vscode/
*.swp
*.swo

# Test artifacts
test-results/
playwright-report/

# Logs
*.log
npm-debug.log*

# OCR model cache (large binary files)
.ocr-cache/

# Playwright persistent browser profile (Chrome cache, massive binary blobs)
exports/figma-playwright-profile/

# macOS metadata
._*

# Sensitive local report exports — never commit (financial/tips data)
/*.csv

# Figma workflow automation artifacts — not needed to run the app
figma-workflow-screenshots/

# Local n8n workflow export working copies (canonical versions live in n8n/)
I9 Folder/
IDV Folder/
