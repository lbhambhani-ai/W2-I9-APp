# Port the Express server listens on (Replit sets this automatically)
PORT=3001

# n8n webhook URL for identity document verification (Gemini Vision)
IDENTITY_VERIFICATION_SERVICE_URL=https://instawork.app.n8n.cloud/webhook/identity/verify-document

# n8n webhook URL for I-9 document verification
I9_VERIFICATION_URL=https://instawork.app.n8n.cloud/webhook/i9/verify-document

# Optional: shared secret header sent to n8n for security
IDENTITY_VERIFICATION_SERVICE_SECRET=

# Optional: n8n webhook URL that appends audit attempt/summary rows to Google Sheets
AUDIT_LOG_WEBHOOK_URL=https://instawork.app.n8n.cloud/webhook/audit-log

# Optional: shared secret header sent to the audit n8n webhook
AUDIT_LOG_WEBHOOK_SECRET=

# Python OCR sidecar — set to "false" to disable local fallback (default: enabled)
ENABLE_PYTHON_OCR=true

# Port the Python OCR sidecar listens on (default: 8001)
PYTHON_OCR_PORT=8001

# Override Python OCR URL if running on a different host
PYTHON_OCR_URL=http://localhost:8001/verify
