# Port the Express server listens on (Replit sets this automatically)
PORT=3001

# n8n webhook URL for document validation (Gemini Vision)
DOCUMENT_VALIDATION_SERVICE_URL=https://instawork.app.n8n.cloud/webhook/identity/verify-document

# n8n webhook URL for I-9 document verification
I9_VERIFICATION_URL=https://instawork.app.n8n.cloud/webhook/i9/verify-document

# Optional: shared secret header sent to document validation n8n workflow
DOCUMENT_VALIDATION_SERVICE_SECRET=

# Optional: shared secret header sent to I-9 n8n workflow.
# If blank, the server falls back to DOCUMENT_VALIDATION_SERVICE_SECRET.
I9_VERIFICATION_SECRET=

# Optional: n8n webhook URL that appends audit attempt/summary rows to Google Sheets
AUDIT_LOG_WEBHOOK_URL=https://instawork.app.n8n.cloud/webhook/audit-log

# Optional: shared secret header sent to the audit n8n webhook.
# Set the SAME value as an n8n Variable named AUDIT_LOG_WEBHOOK_SECRET so the
# workflow's "Check Secret" node rejects unauthenticated requests (401).
AUDIT_LOG_WEBHOOK_SECRET=

# Optional: Intercom API key — used to look up the contact's name + email only for audit events.
# When set, the server calls the Intercom Contacts Search API to look up the user by their
# Instawork user ID (?uid= URL param) or email (?email= URL param) appended to the sim link.
# Generate at: https://app.intercom.com/a/apps/<workspace>/settings/integrations/developer-hub
INTERCOM_API_KEY=

# Python OCR sidecar — set to "false" to disable local fallback (default: enabled)
ENABLE_PYTHON_OCR=true

# Port the Python OCR sidecar listens on (default: 8001)
PYTHON_OCR_PORT=8001

# Override Python OCR URL if running on a different host
PYTHON_OCR_URL=http://localhost:8001/verify
